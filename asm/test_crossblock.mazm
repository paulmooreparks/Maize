stage_b:
    CMP $01 R0.B0             ; the sled-1 marker must have survived
    JNZ fail

    ; ---- all checks passed ----
    CP $01 R0
    CP pass_string R1.H0
    CP $0F R2                 ; 15 bytes ("crossblk: PASS\n")
    SYS $01
    HALT

fail:
    CP $01 R0
    CP fail_string R1.H0
    CP $0F R2                 ; 15 bytes ("crossblk: FAIL\n")
    SYS $01
    HALT

; **********************************************************************************
pass_string:
    STRING "crossblk: PASS\n\0"

fail_string:
    STRING "crossblk: FAIL\n\0"
