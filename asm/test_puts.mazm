; **********************************************************************************
; Regression test for card maize-34: the sys_puts syscall (SYS $F0).
;
; sys_puts(R0=fd, R1=ptr) scans from ptr for the first $00 byte and writes the
; bytes before it to fd (NUL not written; no implicit newline). RV holds the
; underlying write()'s byte count. This test drives SYS $F0 directly (no runtime
; wrapper) and self-checks the return value, then emits its result through the
; same syscall so stdout end-to-end verifies the write path.
; **********************************************************************************

$0000`0000:
    ; ---- empty string: writes nothing, returns 0 (empty-buffer guard) ----
    CP $01 R0               ; fd = 1 (stdout)
    CP empty_string R1      ; ptr -> a lone $00
    SYS $F0
    CMP $00 RV.B0           ; RV must be 0 (no bytes written)
    JNZ fail

    ; ---- non-empty string: write the pass text; RV must equal its length ----
    ; pass_string is "puts: PASS\n\0" -> 11 bytes before the NUL ($0B). A correct
    ; scan writes exactly those 11 bytes (the '\n' is part of the string, NOT an
    ; implicit newline) and returns 11.
    CP $01 R0               ; fd = 1
    CP pass_string R1       ; ptr -> "puts: PASS\n\0"
    SYS $F0
    CMP $0B RV.B0           ; 11 bytes written, NUL excluded, no extra newline
    JNZ fail                ; wrong count also garbles stdout -> harness fails too
    HALT

fail:
    CP $01 R0
    CP fail_string R1
    SYS $F0
    HALT

; **********************************************************************************
empty_string:
    STRING "\0"

pass_string:
    STRING "puts: PASS\n\0"

fail_string:
    STRING "puts: FAIL\n\0"
