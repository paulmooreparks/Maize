; **********************************************************************************
; Headless regression test for the maize-236 framebuffer REGISTRATION TABLE.
;
; Exercises the device-visible ABI at the port level in supervisor mode, with no
; quesOS involved. The registration table generalizes the maize-140 one-shot takeover
; latch into fb_max_slots (8) independent slots:
;   0x53 base   (R/W: base of the SELECTED slot; nonzero claims, zero releases)
;   0x55 status (R: bit0 vsync-pending, bit2 register-rejected)
;   0x56 slot   (R/W: select the slot 0x53/0x54/0x55 act on; reset 0)
;   0x57 active (R/W: W switch the scanned-out surface; R the active slot / sentinel)
; The console sentinel (0xFFFFFFFF) selects the text console on 0x57.
;
; The SAME binary self-adapts to the host display policy so run-tests.sh can drive it
; three ways from one .mzb:
;   * default (display available)                -> the claim/activate/switch-back suite
;   * --fb-no-display                            -> the per-exec rejection suite (bit2)
;   * --fb-no-display --fb-stop-on-claim         -> the claim powers the VM off (no output)
; It selects a branch by observing STATUS bit2 after the first claim attempt.
;
; Buffers sit at $00100000 / $00200000, well past the image and vector table. Prints
; "fbreg: PASS".
; **********************************************************************************

$0000`0000:
    ; ---- slot-select roundtrip: select slot 0, read it back ($56) ----
    CLR R0
    OUT R0.B0 $56
    IN  $56 R1.B0
    CMP $00 R1.B0
    JNZ fail

    ; ---- attempt to claim slot 0 (nonzero base on $53) ----
    ; With --fb-stop-on-claim the VM powers off on this OUT (no further execution, no
    ; output); the bespoke AC7 runner asserts exactly that. Otherwise execution continues.
    CP  $00100000 R2
    OUT R2 $53

    ; ---- branch on STATUS bit2 (register-rejected) ----
    IN  $55 R3.B0
    AND $04 R3.B0
    JNZ reject_path

    ; ================================================================================
    ; claim_path: the display was available, so slot 0 is claimed (AC2-AC5).
    ; ================================================================================
    ; base readback on the selected slot returns the programmed base
    IN  $53 R4.H0
    CP  $00100000 R9.H0
    CMP R4.H0 R9.H0
    JNZ fail

    ; a second slot claims independently of the first
    CP  $01 R0
    OUT R0.B0 $56
    CP  $00200000 R5
    OUT R5 $53
    IN  $53 R6.H0
    CP  $00200000 R9.H0
    CMP R6.H0 R9.H0
    JNZ fail

    ; slot 0 still holds its own base (per-slot independence)
    CLR R0
    OUT R0.B0 $56
    IN  $53 R7.H0
    CP  $00100000 R9.H0
    CMP R7.H0 R9.H0
    JNZ fail

    ; ---- ACTIVATE ($57): the first-ever claim auto-activated slot 0 ----
    IN  $57 R8.H0
    CP  $00000000 R9.H0
    CMP R8.H0 R9.H0
    JNZ fail

    ; writing a claimed slot switches the active surface to it
    CP  $01 R0
    OUT R0.B0 $57
    IN  $57 R8.H0
    CP  $00000001 R9.H0
    CMP R8.H0 R9.H0
    JNZ fail

    ; writing the console sentinel switches back to the console
    CP  $FFFFFFFF R0.H0
    OUT R0.H0 $57
    IN  $57 R8.H0
    CP  $FFFFFFFF R9.H0
    CMP R8.H0 R9.H0
    JNZ fail

    ; writing an UNCLAIMED slot index is a defined no-op (active surface unchanged)
    CP  $05 R0
    OUT R0.B0 $57
    IN  $57 R8.H0
    CP  $FFFFFFFF R9.H0
    CMP R8.H0 R9.H0
    JNZ fail

    ; writing an OUT-OF-RANGE slot index is a defined no-op
    CP  $63 R0
    OUT R0.B0 $57
    IN  $57 R8.H0
    CP  $FFFFFFFF R9.H0
    CMP R8.H0 R9.H0
    JNZ fail

    ; ---- switch-back-on-release (AC4) ----
    ; activate A (slot 0), then B (slot 1); release B; scanout reverts to A (not console)
    CLR R0
    OUT R0.B0 $57
    CP  $01 R0
    OUT R0.B0 $57
    CP  $01 R0
    OUT R0.B0 $56
    CLR R0
    OUT R0 $53
    IN  $57 R8.H0
    CP  $00000000 R9.H0
    CMP R8.H0 R9.H0
    JNZ fail

    ; ---- no-history-fallback (AC5) ----
    ; only slot 0 (A) remains claimed and active; releasing it reverts to the console
    CLR R0
    OUT R0.B0 $56
    CLR R0
    OUT R0 $53
    IN  $57 R8.H0
    CP  $FFFFFFFF R9.H0
    CMP R8.H0 R9.H0
    JNZ fail

    JMP pass

; ================================================================================
; reject_path: the display was unavailable, so the claim was rejected (AC6).
; ================================================================================
reject_path:
    ; the slot must NOT be claimed: its base readback stays 0
    IN  $53 R4.H0
    CP  $00000000 R9.H0
    CMP R4.H0 R9.H0
    JNZ fail

    ; STATUS bit2 (register-rejected) must be set
    IN  $55 R3.B0
    AND $04 R3.B0
    JZ  fail

    ; the active surface is unchanged (console) and the VM is still running (we are here)
    IN  $57 R8.H0
    CP  $FFFFFFFF R9.H0
    CMP R8.H0 R9.H0
    JNZ fail

    JMP pass

; ================================================================================
pass:
    CLR R0
    CLR R1
    CLR R2
    CP  $01 R0
    CP  pass_string R1
    CP  $0C R2              ; 12 bytes
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP  $01 R0
    CP  fail_string R1
    CP  $0C R2              ; 12 bytes
    SYS $01
    HALT

; **********************************************************************************
pass_string:
    STRING "fbreg: PASS\n\0"

fail_string:
    STRING "fbreg: FAIL\n\0"
