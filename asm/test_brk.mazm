; **********************************************************************************
; Regression test for card maize-10: BRK dispatch.
;
; Decision D6460: BRK dispatches as a no-op (advance PC only, no other side effect),
; mirroring NOP. This test confirms BRK neither halts execution nor corrupts state:
; a normal instruction immediately after BRK must still execute correctly.
; **********************************************************************************

$0000`0000:
    CLR R0
    BRK
    CP $01 R0.B0
    CMP $01 R0.B0
    JNZ fail

    ; ---- all checks passed ----
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1
    CP $0A R2               ; 10 bytes
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1
    CP $0A R2               ; 10 bytes
    SYS $01
    HALT

; **********************************************************************************
pass_string:
    STRING "brk: PASS\n\0"

fail_string:
    STRING "brk: FAIL\n\0"
