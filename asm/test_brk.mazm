; **********************************************************************************
; Regression test for card maize-78 (Open Question O7, superseding maize-10 D6460):
; BRK ($FF) is a DEFINED breakpoint trap, not a no-op.
;
; With no handler installed (the shared trap/interrupt vector table is maize-21's to
; deliver and does not exist yet) an unhandled breakpoint halts the VM deterministically
; with the breakpoint cause surfaced, exactly as an unhandled divide-error does. The
; instruction immediately after BRK must therefore NEVER execute. Under the old no-op
; behavior it would fall through, print "brk: FAIL", and exit 0; the run-tests.sh
; bespoke runner (run_brk_trap_test) asserts the opposite: a nonzero exit, a
; "breakpoint" diagnostic on stderr, and no fall-through marker on stdout.
; **********************************************************************************

$0000`0000:
    CLR R0
    BRK

    ; ---- unreachable: only runs if BRK is (wrongly) a no-op ----
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1
    CP $0A R2               ; 10 bytes
    SYS $01
    HALT

; **********************************************************************************
fail_string:
    STRING "brk: FAIL\n\0"
