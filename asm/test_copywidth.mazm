; **********************************************************************************
; Regression test for card maize-29: immediate-width copy semantics.
;
; Contract: CP sign-extends a narrow source to the destination register width and CPZ
; zero-extends it; an explicit narrower destination subregister is the partial-write
; escape hatch. A load (LD) takes its width from the destination subregister. This
; unifies every immediate-load site (CP, the ALU immediate operands, stack/pointer
; loads) on one rule.
; **********************************************************************************

$0000`0000:
    ; ---- 1. CP sign-extends a positive narrow immediate into a full register ----
    CLR R5
    NOT R5                     ; R5 = 0xFFFFFFFFFFFFFFFF (dirty upper bytes)
    CP $01 R5                  ; sign-extend 0x01 -> R5 = 1 (upper bytes cleared)
    CLR R6
    CP $01 R6
    CMP R6 R5
    JNZ fail

    ; ---- 2. CP sign-extends a negative narrow immediate (high bit set) ----
    CLR R5
    CP $FF R5                  ; sign-extend byte 0xFF -> R5 = 0xFFFFFFFFFFFFFFFF
    CLR R6
    NOT R6                     ; R6 = 0xFFFFFFFFFFFFFFFF
    CMP R6 R5
    JNZ fail

    ; ---- 3. An explicit subregister destination is a partial write ----
    CLR R5
    NOT R5                     ; R5 = 0xFFFFFFFFFFFFFFFF
    CP $01 R5.B0               ; partial: only byte 0 -> R5 = 0xFFFFFFFFFFFFFF01
    CP $FFFFFFFFFFFFFF01 R6    ; expected value, full-width immediate
    CMP R6 R5
    JNZ fail

    ; ---- 4. ALU narrow immediate no longer leaks stale operand upper bytes ----
    CLR R3
    ADD $FFFFFFFFFFFFFF00 R3   ; wide immediate dirties the ALU op1 upper bytes
    CLR R5
    CP $05 R5
    ADD $01 R5                 ; sign-extended clean -> R5 = 6 (not 5 + garbage)
    CLR R6
    CP $06 R6
    CMP R6 R5
    JNZ fail

    ; ---- 5. CPZ zero-extends a narrow immediate (distinct from CP) ----
    CLR R5
    NOT R5                     ; R5 = 0xFFFFFFFFFFFFFFFF
    CPZ $FF R5                 ; zero-extend byte 0xFF -> R5 = 0x00000000000000FF
    CLR R6
    CP $FF R6.B0               ; R6 = 0x00000000000000FF (cleared, then low byte)
    CMP R6 R5
    JNZ fail

    ; ---- 6. LD reads exactly the destination width: a byte, preserving the rest ----
    CP $1122334455667788 R1
    CP ldbuf R2.H0
    ST R1 @R2                  ; store the 8-byte pattern (little-endian) at ldbuf
    CLR R0
    NOT R0                     ; R0 = 0xFFFFFFFFFFFFFFFF
    LD @R2 R0.B0               ; load one byte -> R0.B0 = 0x88, upper bytes preserved
    CP $FFFFFFFFFFFFFF88 R3
    CMP R3 R0
    JNZ fail

    ; ---- 7. LD reads four bytes into a 32-bit destination subregister ----
    CLR R0
    NOT R0
    LD @R2 R0.H0               ; load four bytes -> R0.H0 = 0x55667788, upper preserved
    CP $FFFFFFFF55667788 R3
    CMP R3 R0
    JNZ fail

    ; ---- all checks passed ----
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1.H0
    CP $10 R2                  ; 16 bytes
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1.H0
    CP $10 R2                  ; 16 bytes
    SYS $01
    HALT

; **********************************************************************************
ldbuf:
    STRING "ABCDEFGH"          ; 8-byte scratch buffer for the LD sized-load checks

pass_string:
    STRING "copywidth: PASS\n"

fail_string:
    STRING "copywidth: FAIL\n"
