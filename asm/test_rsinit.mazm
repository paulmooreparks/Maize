; **********************************************************************************
; Regression test for the process-start stack contract (card maize-57, as amended by
; card maize-60).
;
; maize-57 originally guaranteed RS = 0xFFFFFFFFFFFFFFF8 with an empty initial stack.
; maize-60 amends that: the VM now builds a System V-style process-start block at the
; top of RAM and points RS at its base, so RS points at argc. This program captures
; that block as its FIRST observable action and asserts the amended contract:
;
;   [RS + 0]   argc            == 1  (the harness runs `maize <image>` with no guest
;                                     args, so argv is just argv[0])
;   [RS + 8]   argv[0]         != 0  (points at the image string, image-as-invoked)
;   [RS + 16]  argv[1]         == 0  (argv[] NULL terminator)
;   [RS + 24]  envp[0]         == 0  (envp[] NULL terminator; envc == 0, and envp is
;                                     NULL-terminated even when empty)
;
; It then exercises the stack region BELOW the block with no prior SP setup: a CALL
; whose return address must round-trip, and a PUSH/POP inside the leaf. The PASS line
; prints via SYS $01 only if the block assertions AND the round-trip all hold.
; **********************************************************************************

$0000`0000:
    ; ---- FIRST observable action: RS points at argc ----
    LD @RS R0                       ; R0 = argc = [RS]
    CMP $01 R0                      ; harness passes no guest args => argc == 1
    JNZ fail

    LEA $08 RS RT                   ; RT = &argv[0]
    LD @RT R1                       ; R1 = argv[0] pointer
    CMP $00 R1                      ; argv[0] must be non-NULL (the image string)
    JZ fail

    LEA $10 RS RT                   ; RT = &argv[1] (argv NULL terminator, argc == 1)
    LD @RT R1
    CMP $00 R1                      ; argv[] must be NULL-terminated
    JNZ fail

    LEA $18 RS RT                   ; RT = &envp[0] (envp NULL terminator, envc == 0)
    LD @RT R1
    CMP $00 R1                      ; envp[] must be NULL-terminated even when empty
    JNZ fail

    ; ---- exercise the stack region below the block, no prior SP setup ----
    ; CALL pushes the return address below RS; the leaf also PUSH/POPs a sentinel. If
    ; the stack were not usable, the return address would not round-trip and control
    ; would not reach the PASS line.
    CLR R4
    CALL sub_leaf                  ; sets R4.B0 = $01 and returns here
    CMP $01 R4.B0
    JNZ fail

    ; ---- all checks passed ----
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1.H0
    CP $0D R2                      ; 13 bytes
    SYS $01
    HALT

sub_leaf:
    ; Push a sentinel and pop it back to confirm PUSH/POP round-trips on the stack
    ; region below the block, then signal success to the caller.
    CP $CAFEF00DDEADBEEF R5
    PUSH R5
    CLR R6
    POP R6
    CMP R5 R6
    JNZ fail                       ; PUSH/POP did not round-trip
    CP $01 R4.B0
    RET                            ; return address must round-trip through the stack

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1.H0
    CP $0D R2                      ; 13 bytes
    SYS $01
    HALT

; **********************************************************************************
pass_string:
    STRING "rsinit: PASS\n\0"

fail_string:
    STRING "rsinit: FAIL\n\0"
