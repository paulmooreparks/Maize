; **********************************************************************************
; Regression test for card maize-196: ALU/CMP memory-source operands read at the
; operation (destination-subregister) width, not a fixed 8 bytes.
;
; The qbe-maize backend only ever emits FULL-WIDTH ALU-with-memory-source operands,
; so the whole C/asm corpus never exercises a sub-width one. This fixture drives the
; sub-width regAddr ALU forms by hand and checks the computed VALUE, which locks the
; read-width contract. It also covers a HIGH-OFFSET destination (R0.B3): the fixed
; read must land the source at offset 0 (width0_subreg), where the ALU handler reads
; it -- reading it into the destination's own subregister offset instead would leave
; the handler consuming stale bytes. The over-read itself is not guest-observable
; under the current sparse memory (it reads adjacent zero-fill), so this asserts the
; value semantics; the read-width narrowing is a code-review + no-regression matter.
; **********************************************************************************

$0000`0000:
    ; Store an 8-byte little-endian pattern at membuf. Byte 0 = 0x88, the low
    ; halfword = 0x7788, the low word = 0x55667788.
    CP $1122334455667788 R1
    CP membuf R2.H0
    ST R1 @R2

    ; ---- 1. byte-width ADD from memory, offset-0 destination ----
    CP $FFFFFFFFFFFFFF10 R0     ; dirty upper bytes, B0 = 0x10
    ADD @R2 R0.B0              ; 0x10 + 0x88 = 0x98 into B0, upper preserved
    CP $FFFFFFFFFFFFFF98 R3
    CMP R3 R0
    JNZ fail

    ; ---- 2. byte-width ADD, HIGH-OFFSET destination (B3) ----
    ; The differentiator: a naive "read at the destination subreg" would place the
    ; byte at offset 3 and the handler would then add stale offset-0 bytes.
    CP $FFFFFFFF10FFFFFF R0     ; B3 = 0x10, rest dirty
    ADD @R2 R0.B3             ; 0x10 + 0x88 = 0x98 into byte 3, rest preserved
    CP $FFFFFFFF98FFFFFF R3
    CMP R3 R0
    JNZ fail

    ; ---- 3. halfword-width ADD from memory ----
    CP $FFFFFFFF00000010 R0     ; H0 = 0x00000010
    ADD @R2 R0.H0             ; 0x10 + 0x55667788 = 0x55667798, upper preserved
    CP $FFFFFFFF55667798 R3
    CMP R3 R0
    JNZ fail

    ; ---- 4. CMP memory-source (no-write form): byte compare ----
    CP $0000000000000088 R0     ; B0 = 0x88 == membuf[0]
    CMP @R2 R0.B0             ; R0.B0 - membuf[0] == 0 -> Z set
    JNZ fail
    CP $0000000000000077 R0     ; B0 = 0x77 != membuf[0]
    CMP @R2 R0.B0             ; nonzero -> Z clear
    JZ fail

    ; ---- all checks passed ----
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1.H0
    CP $17 R2                  ; 23 bytes
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1.H0
    CP $17 R2                  ; 23 bytes
    SYS $01
    HALT

; **********************************************************************************
membuf:
    STRING "ABCDEFGH"          ; 8-byte scratch (overwritten by the ST above)

pass_string:
    STRING "alu memsrc width: PASS\n"

fail_string:
    STRING "alu memsrc width: FAIL\n"
