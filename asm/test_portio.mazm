; **********************************************************************************
; Regression test for card maize-21: the $94 OUT out_regAddr_imm form transfers the
; value LOADED from the source address, not the raw source address.
;
; $94 ("value at the address in the source register") loaded the memory operand into a
; temporary but then wrote the raw source register to the device, so the load was dead
; and the wrong value was transferred. The sibling address forms ($D4 / $9E / $DE)
; already wrote the loaded value; this fixture regression-guards the $94 fix by
; round-tripping a value through the loopback device (port 1) with the $94 form and
; asserting the LOADED byte ($CD), not the address low byte ($00), landed.
;
; The assembler has no surface syntax for the OUT/OUTR/IN memory-address forms (the OUT
; compiler emits only the register-value and immediate-value forms), so the $94
; instruction is hand-encoded here as raw bytes:
;
;   $94 $5E $00 $01  =  OUT @R5 $01
;     $94  out_regAddr_imm
;     $5E  op1 = R5.w0  (the register holding the source address)
;     $00  op2 = 8-bit immediate port operand
;     $01  the port literal (the loopback device)
; **********************************************************************************

$0000`0000:
    ; ---- stage a known value at a known memory address ----
    CLR R0
    CP $CD R0.B0           ; the value to transfer
    CLR R1
    CP $2000 R1            ; the memory address that holds it
    ST R0 @R1              ; mem[$2000] = $00000000000000CD

    ; ---- R5 = the source address ($2000); its low byte $00 is distinct from $CD ----
    CLR R5
    CP $2000 R5

    ; ---- $94: OUT the value AT the address in R5 to port 1 (hand-encoded) ----
    DATA $94 $5E $00 $01   ; OUT @R5 $01: device <- mem[R5] ($CD), NOT R5 ($2000)

    ; ---- read the loopback device back and assert the LOADED value landed ----
    CLR R6
    IN $01 R6.B0
    CMP $CD R6.B0          ; the fix transfers $CD; the old bug transferred $00
    JNZ fail

    ; ---- all checks passed ----
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1
    CP $0D R2              ; 13 bytes
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1
    CP $0D R2              ; 13 bytes
    SYS $01
    HALT

; **********************************************************************************
pass_string:
    STRING "portio: PASS\n\0"

fail_string:
    STRING "portio: FAIL\n\0"
