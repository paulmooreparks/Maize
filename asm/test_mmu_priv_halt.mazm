; **********************************************************************************
; Regression test for card maize-180: HALT is privileged (cause-4 in user mode).
;
; HALT was previously ungated. This card gives it the same head-of-dispatch privilege
; guard as IN/OUT. Dropping to user mode via the IRET trampoline and executing HALT must
; raise the cause-4 "privileged operation in user mode" fault: the VM exits nonzero with
; a "privileged" diagnostic and never reaches the fall-through "mmu-priv-halt: FAIL"
; marker (a regression that left HALT ungated would instead power off cleanly, exit 0,
; and print no diagnostic -- which the trap-style runner also catches as a failure).
;
; RF bit layout (src/cpu.cpp): bit_privilege = bit 32, bit_running = bit 35.
; **********************************************************************************

$0000`0000:
    CLR R0
    CP user_mode R0.H0
    PUSH R0                ; [SP] = user_mode (restored PC)

    CLR R1
    CP $08 R1.B4           ; running set, privilege clear
    PUSH R1                ; [SP] = user RF

    IRET                   ; enter user mode

user_mode:
    ; ---- now unprivileged: this HALT must raise the cause-4 fault ----
    HALT                   ; privileged in user mode -> cause-4 fault

    ; ---- unreachable unless the privilege gate wrongly let HALT through ----
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1
    CP $14 R2              ; 20 bytes
    SYS $01
    HALT

; **********************************************************************************
fail_string:
    STRING "mmu-priv-halt: FAIL\n\0"
