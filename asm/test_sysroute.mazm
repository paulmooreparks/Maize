; **********************************************************************************
; Regression test for card maize-24 (decision D9, Shape B): the SYS provider-select
; mode flag and its guest-owned trap routing, proven WITHOUT a full quesOS.
;
; The guest installs a cause-7 (SYS) handler in the shared trap-vector table at
; entry[7] = $1000 + 7*8 = $1038, sets the syscall-guest flag with SETSYSG, and
; issues SYS $42. With the flag set, SYS traps through cause 7 into the handler
; instead of calling the native provider; the syscall number rides the frame's aux
; word ([RS] on handler entry). The handler captures that number into a memory
; marker and leaves an RV sentinel, then IRETs. Back in the main flow the guest
; clears the flag with CLRSYSG, verifies the handler saw number $42 and left RV=$99
; (round-trip marker), and then prints "sysroute: PASS" via a NATIVE SYS $01 write,
; which proves native SYS dispatch resumes once the flag is cleared. Any break in the
; routing (flag not honored, wrong number delivered, native not restored) diverts or
; drops the PASS line.
; **********************************************************************************

$0000`0000:
    ; ---- install the cause-7 handler at entry[7] ($1038) ----
    CLR R0
    CP sys_handler R0.H0
    CLR R1
    CP $1038 R1
    ST R0 @R1                 ; entry[7] = sys_handler (full 64-bit address)

    ; ---- zero the captured-number marker ----
    CLR R0
    CLR R1
    CP marker R1.H0
    ST R0 @R1

    ; ---- route SYS to the guest, then issue SYS $42 (traps through cause 7) ----
    SETSYSG
    SYS $42

    ; ---- restore native SYS dispatch for the checks and the print below ----
    CLRSYSG

    ; ---- verify the handler captured syscall number $42 in the marker ----
    CLR R1
    CP marker R1.H0
    CLR R2
    LD @R1 R2
    CMP $42 R2
    JNZ fail

    ; ---- verify the handler left the RV round-trip sentinel $99 ----
    CMP $99 RV
    JNZ fail

    ; ---- native SYS resumes: write the PASS line via SYS $01 ----
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1.H0
    CP $0F R2                 ; 15 bytes: "sysroute: PASS\n"
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1.H0
    CP $0F R2                 ; 15 bytes: "sysroute: FAIL\n"
    SYS $01
    HALT

; **********************************************************************************
; Cause-7 (SYS) handler. On entry RS points at the frame's aux word (frame, from RS
; upward: aux, cause, RF, PC). aux is the SYS operand, i.e. the syscall number. Read
; it before touching RS, record it and an RV sentinel, discard the two trap-only
; words (aux + cause), and return through the shared IRET (pops RF then PC). The
; handler runs with the syscall-guest flag still set; it does not re-issue SYS, so no
; native passthrough is exercised here (that path is quesOS's job).
sys_handler:
    LD @RS R8                 ; R8 = aux = delivered syscall number
    CLR R9
    CP marker R9.H0
    ST R8 @R9                 ; marker = captured number
    CLR RV
    CP $99 RV                 ; RV round-trip sentinel (survives IRET)
    ADD $10 RS                ; discard aux + cause; RS now at the saved RF
    IRET                      ; pop RF (restores flags), pop PC (resume after SYS $42)

; **********************************************************************************
marker:
    DATA $00 $00 $00 $00 $00 $00 $00 $00   ; 8-byte captured-number marker

pass_string:
    STRING "sysroute: PASS\n\0"

fail_string:
    STRING "sysroute: FAIL\n\0"
