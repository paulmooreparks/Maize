; **********************************************************************************
; MUL-by-zero regression test for card maize-86.
;
; Before this fix, is_mul_overflow / is_mul_underflow (src/cpu.cpp) divided by the
; second operand (limits<T>::max()/b, min()/b) with no b == 0 guard, so any MUL
; with a zero factor crashed the VM with SIGFPE. This test exercises that path at
; more than one width and asserts the VM completes normally, the product is 0, and
; the flags come out Z=1 / V=0 / C=0 / N=0 (a product of exactly 0 fits every
; width, so it can neither overflow nor underflow).
;
; Cases:
;   A. Full-width (W, 8-byte) MUL by an immediate zero second operand, nonzero
;      accumulator: R0 = $123456789ABCDEF0, MUL $00 R0 -> R0 = 0.
;   B. Full-width (W) MUL where the accumulator/destination is itself zero and the
;      second operand is nonzero: R0 = 0, R1 = $123456789ABCDEF0, MUL R1 R0 -> R0 = 0.
;   C. Byte-width (B) MUL by zero, for width coverage beyond the full-width case:
;      R0.B0 = $7F, R1.B0 = 0, MUL R1.B0 R0.B0 -> R0.B0 = 0.
;
; Flags are read from RF.B0 (C=$01 N=$02 V=$04 P=$08 Z=$10) immediately after each
; MUL (before any flag-touching instruction, including test_assert_eq's own CMP)
; and masked with $17 (C|N|V|Z, skipping P which MUL does not define) so a single
; test_assert_eq call per case verifies all four required flags at once: the only
; passing combined value is $10 (Z set, C/N/V clear).
;
; See asm/test_flags_arith.mazm for the INCLUDE-placement rationale (numeric-address
; "$0000`0000:" header resets current_address, so lib/test.mazm is appended AFTER
; this file's own runnable code rather than before it).
; **********************************************************************************

$0000`0000:
    ; ---- Case A: full-width MUL $00, nonzero accumulator ----
    CP $123456789ABCDEF0 R0    ; nonzero W-width accumulator
    MUL $00 R0                 ; R0 = R0 * 0 = 0 (previously SIGFPE)
    CP RF.B0 R9.B0             ; snapshot flags before test_assert_eq's own CMP

    CP R0 R2                    ; save actual product before clobbering R0
    CLR R0                      ; expected: 0
    CP R2 R1                    ; actual
    CP fail_product_a R2
    CALL test_assert_eq

    CLR R8
    CP R9.B0 R8.B0
    AND $17 R8.B0               ; isolate C|N|V|Z
    CP $10 R0                   ; expected: Z set only
    CP R8 R1
    CP fail_flags_a R2
    CALL test_assert_eq

    ; ---- Case B: full-width MUL, zero accumulator / nonzero second operand ----
    CLR R0                      ; accumulator = 0
    CP $123456789ABCDEF0 R1     ; nonzero second operand
    MUL R1 R0                   ; R0 = 0 * R1 = 0 (previously SIGFPE)
    CP RF.B0 R9.B0

    CP R0 R2                    ; actual product (already 0, but compare explicitly)
    CLR R0
    CP R2 R1
    CP fail_product_b R2
    CALL test_assert_eq

    CLR R8
    CP R9.B0 R8.B0
    AND $17 R8.B0
    CP $10 R0
    CP R8 R1
    CP fail_flags_b R2
    CALL test_assert_eq

    ; ---- Case C: byte-width (B) MUL by zero, for multi-width coverage ----
    CLR R0
    CLR R1
    CP $7F R0.B0                ; nonzero byte accumulator
    CLR R1.B0                   ; zero byte second operand
    MUL R1.B0 R0.B0             ; R0.B0 = R0.B0 * R1.B0 = 0 (previously SIGFPE)
    CP RF.B0 R9.B0

    CLR R2
    CP R0.B0 R2.B0               ; actual product (byte)
    CLR R0
    CP R2 R1
    CP fail_product_c R2
    CALL test_assert_eq

    CLR R8
    CP R9.B0 R8.B0
    AND $17 R8.B0
    CP $10 R0
    CP R8 R1
    CP fail_flags_c R2
    CALL test_assert_eq

    ; ---- all checks passed ----
    CP pass_string R0
    CALL test_report_pass      ; never returns

; **********************************************************************************
pass_string:
    STRING "mul zero: PASS\n\0"

fail_product_a:
    STRING "mul zero: FAIL (case A product)\n\0"

fail_flags_a:
    STRING "mul zero: FAIL (case A flags)\n\0"

fail_product_b:
    STRING "mul zero: FAIL (case B product)\n\0"

fail_flags_b:
    STRING "mul zero: FAIL (case B flags)\n\0"

fail_product_c:
    STRING "mul zero: FAIL (case C product)\n\0"

fail_flags_c:
    STRING "mul zero: FAIL (case C flags)\n\0"

; **********************************************************************************
; Library INCLUDE appended here rather than at the top of the file (see the
; INCLUDE-placement note above the "$0000`0000:" header): lib/test.mazm's routines
; use plain-name labels, so splicing them in here places them at whatever address
; current_address has reached after this file's own code and data, monotonically
; after it, instead of colliding with the numeric-address reset that
; "$0000`0000:" performs.
INCLUDE "lib/test.mazm"
