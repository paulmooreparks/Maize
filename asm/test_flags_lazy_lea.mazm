; **********************************************************************************
; Lazy-flags boundary test (card maize-197): LEA after a PENDING ALU op.
;
; LEA computes an address via an internal run_alu(ADD) but must be flag-neutral
; (card maize-4). Under lazy flags that internal ADD STAGES a new pending descriptor
; instead of writing RF eagerly, so restoring only the raw RF bits is not enough: the
; handler must snapshot and restore the WHOLE pending_flags_t around the internal add.
; Otherwise a later consumer materializes LEA's internal add and silently corrupts the
; flags LEA must leave untouched. This is the single highest-risk lazy-flags scenario.
;
; An ALU op establishes a known N/V/Z/C; a LEA runs with a prior op's flags still
; pending; then RF is read back and every bit must match the ALU op, not the LEA add.
;
; LEA idx base dest -> dest = base + idx. RF.B0 bits: C=$01 N=$02 V=$04 P=$08 Z=$10.
; **********************************************************************************

$0000`0000:
    ; ---- SUB ($00 - $01 = $FF): N set, C set (borrow), Z clear, V clear ----
    CP $00 R0.B0
    CP $01 R1.B0
    SUB R1.B0 R0.B0        ; N set, C set, Z clear, V clear (pending, NOT yet read)

    ; LEA with a large positive sum whose own ADD would give N=0,C=0,Z=0,V=0 -- the
    ; exact opposite of SUB's flags, so a leaked LEA-add materialization is visible.
    CP $10 R4              ; idx (flag-neutral load)
    CP $20 R5              ; base (flag-neutral load)
    LEA R4 R5 R6           ; R6 = $20 + $10 = $30; must be flag-neutral

    CP RF.B0 R9.B0         ; materialize the ORIGINAL SUB pending (LEA restored it)

    ; N must be SUB's (set), not LEA's add (clear)
    CLR R8
    CP R9.B0 R8.B0
    AND $02 R8.B0
    CP $02 R0
    CP R8 R1
    CP fail_string R2
    CALL test_assert_eq

    ; C must be SUB's borrow (set), not LEA's add (clear)
    CLR R8
    CP R9.B0 R8.B0
    AND $01 R8.B0
    CP $01 R0
    CP R8 R1
    CP fail_string R2
    CALL test_assert_eq

    ; Z must be SUB's (clear)
    CLR R8
    CP R9.B0 R8.B0
    AND $10 R8.B0
    CLR R0
    CP R8 R1
    CP fail_string R2
    CALL test_assert_eq

    ; V must be SUB's (clear)
    CLR R8
    CP R9.B0 R8.B0
    AND $04 R8.B0
    CLR R0
    CP R8 R1
    CP fail_string R2
    CALL test_assert_eq

    ; ---- also confirm the LEA actually computed the address (R6 == $30) ----
    CP $30 R0
    CP R6 R1
    CP fail_string R2
    CALL test_assert_eq

    ; ---- all checks passed ----
    CP pass_string R0
    CALL test_report_pass     ; never returns

; **********************************************************************************
pass_string:
    STRING "flags lazy lea: PASS\n\0"

fail_string:
    STRING "flags lazy lea: FAIL\n\0"

INCLUDE "lib/test.mazm"
