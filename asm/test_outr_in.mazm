; **********************************************************************************
; Regression test for card maize-10: OUTR / IN dispatch against the loopback test
; device (Decision D6465, registered at port 1 in src/maize.cpp).
;
; Exercises both operand-source paths into the same devices[] entry:
;   - register-specified port: OUTR writes through a register holding the port id,
;     IN reads back through a register holding the port id.
;   - immediate port: OUT writes to a literal port number, IN reads back from a
;     literal port number (Decision D6464: OUTR/IN mirror OUT's own four-case
;     pattern; IN's copy direction is device-to-register).
; **********************************************************************************

$0000`0000:
    ; ---- register-specified-port path: OUTR then IN through a port-holding register ----
    CLR R0
    CP $AB R0.B0             ; value to output
    CLR R1
    CP $01 R1.B0             ; R1 = loopback test port id

    OUTR R0.B0 R1            ; devices[1] = $AB

    CLR R2
    IN R1 R2.B0               ; R2.B0 = devices[1], port id read from R1
    CMP $AB R2.B0
    JNZ fail

    ; ---- immediate-port path: OUT then IN with the port id as a literal ----
    CLR R3
    CP $CD R3.B0
    OUT R3.B0 $01              ; devices[1] = $CD

    CLR R4
    IN $01 R4.B0                ; R4.B0 = devices[1], port id as a literal
    CMP $CD R4.B0
    JNZ fail

    ; ---- all checks passed ----
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1
    CP $0E R2               ; 14 bytes
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1
    CP $0E R2               ; 14 bytes
    SYS $01
    HALT

; **********************************************************************************
pass_string:
    STRING "outr/in: PASS\n\0"

fail_string:
    STRING "outr/in: FAIL\n\0"
