; **********************************************************************************
; Headless regression test for the MEMORY-BACKED framebuffer device.
;
; The framebuffer is not port-per-pixel: pixels live in ordinary guest RAM and are
; written with normal ST stores. The control plane is ports:
;   0x50 width  (R)   0x51 height (R)   0x52 format (R, 1 = XRGB8888)
;   0x53 base   (R/W: guest address of the pixel buffer)
;   0x54 present(W: present a frame; R bit0 = last present valid)
;   0x55 status (R: vsync-pending; W: vsync-IRQ-enable / ack)
;
; This test reads the resolution registers, writes a known pixel pattern into a
; guest-RAM buffer with plain stores, registers the buffer base and presents a frame,
; then self-verifies by reading the pattern back FROM GUEST MEMORY with plain loads. It
; also exercises the bounds/validity check: presenting with an unset base (0) must
; report an invalid present, with no crash. Prints "framebuffer: PASS".
;
; The buffer sits at $00100000 (1 MiB), well past the loaded image and the vector table.
; Default host resolution is 320x200 (width $0140, height $00C8), format id 1.
; **********************************************************************************

$0000`0000:
    ; ---- verify the host-configured geometry (default 320x200, XRGB8888) ----
    IN $50 R0.H0            ; width
    CP $0140 R9.H0
    CMP R0.H0 R9.H0
    JNZ fail

    IN $51 R0.H0            ; height
    CP $00C8 R9.H0
    CMP R0.H0 R9.H0
    JNZ fail

    IN $52 R0.B0            ; pixel format id
    CMP $01 R0.B0
    JNZ fail

    ; ---- write a known pixel pattern into the guest-RAM buffer with plain stores ----
    CP $00100000 R1        ; buffer base (also address of pixel 0)
    CP $00100004 R4        ; address of pixel 1
    CP $00100008 R5        ; address of pixel 2

    CP $11223344 R6.H0
    ST R6.H0 @R1           ; pixel[0]
    CP $0A0B0C0D R7.H0
    ST R7.H0 @R4           ; pixel[1]
    CP $7EADBEEF R8.H0
    ST R8.H0 @R5           ; pixel[2]

    ; ---- register the buffer base and present the frame ----
    OUT R1 $53             ; base-address = $00100000
    OUT R0 $54             ; present (value ignored): device reads the buffer from RAM
    IN $54 R2.B0           ; last-present-valid must be 1
    CMP $01 R2.B0
    JNZ fail

    ; ---- self-verify by reading the pattern back FROM GUEST MEMORY (plain loads) ----
    CLR R2
    LD @R1 R2.H0
    CP $11223344 R9.H0
    CMP R2.H0 R9.H0
    JNZ fail

    CLR R2
    LD @R4 R2.H0
    CP $0A0B0C0D R9.H0
    CMP R2.H0 R9.H0
    JNZ fail

    CLR R2
    LD @R5 R2.H0
    CP $7EADBEEF R9.H0
    CMP R2.H0 R9.H0
    JNZ fail

    ; ---- bounds/validity: an unset base (0) is an invalid present, no crash ----
    CLR R3
    OUT R3 $53             ; base-address = 0 (unset)
    OUT R0 $54             ; present: device must reject (base 0), no host OOB
    IN $54 R2.B0           ; last-present-valid must be 0
    CMP $00 R2.B0
    JNZ fail

    ; ---- all checks passed ----
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1
    CP $12 R2              ; 18 bytes
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1
    CP $12 R2              ; 18 bytes
    SYS $01
    HALT

; **********************************************************************************
pass_string:
    STRING "framebuffer: PASS\n\0"

fail_string:
    STRING "framebuffer: FAIL\n\0"
