; **********************************************************************************
; End-to-end regression test for card maize-21: the timer as the first interrupt
; source, exercising the full raise -> deliver -> handle -> ack -> IRET loop.
;
; The guest installs a handler in the shared vector table at entry[32] (the timer's
; IRQ vector), programs the timer period and mode (periodic + enable), unmasks
; interrupts with SETINT, and spins. The instruction-tick timer fires every period
; instructions; on each fire the CPU delivers through entry[32] with the four-word
; frame, the handler services the tick (incrementing a memory counter), acknowledges
; through the status register (which re-arms the periodic timer), and IRETs back. When
; three ticks have been serviced the guest prints "timer: PASS".
;
; Provisional timer pinout (maize-21): period port $40, control port $41, status/ack
; port $42, IRQ vector 32. The vector table base is $1000, so entry[32] lives at
; $1000 + 32*8 = $1100.
;
; Control register: bit 0 = enable, bit 1 = periodic. Status register: bit 0 =
; tick-pending; writing a value with bit 0 clear acknowledges (clears the source and,
; in periodic mode, re-arms the countdown).
; **********************************************************************************

$0000`0000:
    ; ---- install the timer handler at entry[32] ($1100) ----
    CLR R0
    CP timer_handler R0.H0
    CLR R1
    CP $1100 R1
    ST R0 @R1              ; entry[32] = timer_handler (full 64-bit address)

    ; ---- zero the serviced-tick counter ----
    CLR R0
    CLR R1
    CP tick_count R1.H0
    ST R0 @R1

    ; ---- program the timer: period = 4 ticks, mode = periodic + enable ----
    CLR R0
    CP $04 R0.B0
    OUT R0.B0 $40         ; period register
    CP $03 R0.B0          ; bit0 = enable, bit1 = periodic
    OUT R0.B0 $41         ; control register

    SETINT                ; unmask interrupts

wait_loop:
    CLR R1
    CP tick_count R1.H0
    CLR R2
    LD @R1 R2             ; R2 = serviced-tick count
    CMP $03 R2            ; want three serviced ticks
    JGE done
    JMP wait_loop         ; spin; each instruction advances the timer

done:
    CLRINT
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1.H0
    CP $0C R2             ; 12 bytes
    SYS $01
    HALT

; **********************************************************************************
; Timer interrupt handler. On entry SP points at aux (the four-word frame is, from SP
; upward: aux, cause, RF, PC). Discard the two trap-only words, service the tick, ack
; the timer, and return through the shared IRET (which pops RF then PC). The handler
; runs masked, so it preserves the scratch registers it touches around its work.
timer_handler:
    ADD $10 SP            ; discard aux + cause (2 words); SP now at the saved RF
    PUSH R8
    PUSH R9

    CLR R8
    CP tick_count R8.H0   ; R8 = address of the serviced-tick counter
    LD @R8 R9
    INC R9
    ST R9 @R8            ; ++serviced ticks

    CLR R9
    OUT R9.B0 $42        ; ack: write 0 to the status register (clears pending, re-arms)

    POP R9
    POP R8
    IRET                 ; pop RF (re-enables interrupts), pop PC (resume the spin)

; **********************************************************************************
tick_count:
    DATA $00 $00 $00 $00 $00 $00 $00 $00   ; 8-byte serviced-tick counter

pass_string:
    STRING "timer: PASS\n\0"
