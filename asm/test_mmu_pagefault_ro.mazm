; **********************************************************************************
; Card maize-194 (Sv48 translation), AC 8630: page fault on a write to a read-only page.
;
; Maps VA 0x40000000 read-only (R=1, W=0, U=1) via a full four-level walk, enables Sv48,
; then STOREs through it. The cause-8 handler runs and confirms CR2 bit0 (PRESENT) = 1
; (a permission violation, not a missing mapping) with bits[2:1] (ACCESS_KIND) = store (2)
; and CR1 (FAULT_VA) = 0x40000000, i.e. CR2 = 0x05.
;
;   0x10000 root  Root[0] = 0x11001 -> L2
;   0x11000 L2    L2[0] = 0x1F (identity superpage); L2[1] = 0x12001 -> L1
;   0x12000 L1    L1[0] = 0x13001 -> L0
;   0x13000 L0    L0[0] = 0x14013 leaf -> 0x14000, V R U (W clear: read-only)
; **********************************************************************************

$0000`0000:
    CLR R8
    CP handler R8.H0
    CLR R9
    CP $1040 R9.H0
    ST R8 @R9

    CP $11001 R8
    CLR R9
    CP $10000 R9.H0
    ST R8 @R9

    CP $1F R8
    CLR R9
    CP $11000 R9.H0
    ST R8 @R9

    CP $12001 R8
    CLR R9
    CP $11008 R9.H0
    ST R8 @R9

    CP $13001 R8
    CLR R9
    CP $12000 R9.H0
    ST R8 @R9

    ; L0[0] = 0x14013 -> 0x14000, V R U (read-only: W clear)
    CP $14013 R8
    CLR R9
    CP $13000 R9.H0
    ST R8 @R9

    CLR RS
    CP $00080000 RS.H0

    CP $10001 R0
    MOVTCR R0 $00

    ; ---- store through the read-only VA -> perm-violation fault ----
    CLR R3
    CP $40000000 R3.H0
    CLR R2
    CP $CAFEF00D R2.H0
    ST R2.H0 @R3            ; translate(store): leaf has W=0 -> page fault

    CP $00 R0
    MOVTCR R0 $00
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1.H0
    CP $13 R2
    SYS $01
    HALT

; **********************************************************************************
handler:
    CP $00 R0
    MOVTCR R0 $00

    ; CR1 must equal 0x40000000
    MOVFCR $01 R1
    CLR R2
    CP $40000000 R2.H0
    CMP R2 R1
    JNZ hfail

    ; CR2 must equal 0x05: PRESENT=1, ACCESS_KIND=store(2), USER=0
    MOVFCR $02 R3
    CMP $05 R3
    JNZ hfail

    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1.H0
    CP $13 R2
    SYS $01
    HALT

hfail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1.H0
    CP $13 R2
    SYS $01
    HALT

; **********************************************************************************
pass_string:
    STRING "mmu-fault-ro: PASS\n\0"

fail_string:
    STRING "mmu-fault-ro: FAIL\n\0"
