; **********************************************************************************
; Card maize-122: floating-point ISA conformance fixture.
;
; A self-checking program that exercises the FP op set at both widths (binary32
; via H0, binary64 via W0), all five rounding modes, the sticky FFLAGS, NaN
; handling, and the FCMP integer-flag / JP-predicate mapping. Any failed check
; jumps to `fail`; reaching the end prints "fp: PASS". Bit patterns are IEEE-754
; and were chosen so the value checks are rounding-independent except where a
; rounding mode is the thing under test.
;
; FP operand order follows the ALU convention: `FADD src dst` computes
; dst = dst + src (op1 = source, op2 = destination). FSETCSR writes the whole
; FCSR byte (FRM in bits 7-5, FFLAGS in bits 4-0), which also clears the sticky
; flags; FGETCSR reads it back.
; **********************************************************************************

$0000`0000:
    ; ================= binary32 arithmetic (exact, RNE default) =================
    ; FADD: 1.5 + 2.25 = 3.75
    CP $3FC00000 R0.H0
    CP $40100000 R1.H0
    FADD R0.H0 R1.H0
    CMP $40700000 R1.H0
    JNZ fail

    ; FSUB: 3.75 - 1.5 = 2.25
    CP $40700000 R1.H0
    CP $3FC00000 R0.H0
    FSUB R0.H0 R1.H0
    CMP $40100000 R1.H0
    JNZ fail

    ; FMUL: 1.5 * 2.25 = 3.375
    CP $3FC00000 R0.H0
    CP $40100000 R1.H0
    FMUL R0.H0 R1.H0
    CMP $40580000 R1.H0
    JNZ fail

    ; FDIV: 3.0 / 2.0 = 1.5
    CP $40400000 R1.H0
    CP $40000000 R0.H0
    FDIV R0.H0 R1.H0
    CMP $3FC00000 R1.H0
    JNZ fail

    ; FSQRT: sqrt(4.0) = 2.0
    CP $40800000 R0.H0
    FSQRT R0.H0 R1.H0
    CMP $40000000 R1.H0
    JNZ fail

    ; FNEG / FABS: -(1.5) = -1.5 ; |-1.5| = 1.5
    CP $3FC00000 R0.H0
    FNEG R0.H0 R1.H0
    CMP $BFC00000 R1.H0
    JNZ fail
    FABS R1.H0 R2.H0
    CMP $3FC00000 R2.H0
    JNZ fail

    ; FMIN / FMAX: min(2.25,1.5)=1.5 ; max(2.25,1.5)=2.25
    CP $3FC00000 R0.H0
    CP $40100000 R1.H0
    FMIN R0.H0 R1.H0
    CMP $3FC00000 R1.H0
    JNZ fail
    CP $40100000 R1.H0
    FMAX R0.H0 R1.H0
    CMP $40100000 R1.H0
    JNZ fail

    ; FMADD: 1.5*2.0 + 0.5 = 3.5   (c = a*b + c, c is op3/dst)
    CP $3FC00000 R0.H0
    CP $40000000 R1.H0
    CP $3F000000 R2.H0
    FMADD R0.H0 R1.H0 R2.H0
    CMP $40600000 R2.H0
    JNZ fail

    ; FMSUB: 1.5*2.0 - 0.5 = 2.5
    CP $3F000000 R2.H0
    FMSUB R0.H0 R1.H0 R2.H0
    CMP $40200000 R2.H0
    JNZ fail

    ; ================= binary64 arithmetic =================
    ; FADD double: 1.5 + 2.25 = 3.75
    CP $3FF8000000000000 R0.W0
    CP $4002000000000000 R1.W0
    FADD R0.W0 R1.W0
    CMP $400E000000000000 R1.W0
    JNZ fail

    ; FMUL double: 1.5 * 2.0 = 3.0
    CP $3FF8000000000000 R0.W0
    CP $4000000000000000 R1.W0
    FMUL R0.W0 R1.W0
    CMP $4008000000000000 R1.W0
    JNZ fail

    ; ================= FCMP + branch predicates (binary32) =================
    ; a < src : a=1.5, src=2.25 -> JB taken, JP not taken
    CP $40100000 R0.H0
    CP $3FC00000 R1.H0
    FCMP R0.H0 R1.H0
    JP fail
    JB flt_ok
    JMP fail
flt_ok:

    ; a > src : a=2.25, src=1.5 -> JA taken
    CP $3FC00000 R0.H0
    CP $40100000 R1.H0
    FCMP R0.H0 R1.H0
    JA fgt_ok
    JMP fail
fgt_ok:

    ; a == src : a=1.5, src=1.5 -> JZ taken
    CP $3FC00000 R0.H0
    CP $3FC00000 R1.H0
    FCMP R0.H0 R1.H0
    JZ feq_ok
    JMP fail
feq_ok:

    ; ================= NaN handling via FCMP =================
    ; quiet NaN operand -> unordered (JP), NO FFLAGS.NV
    CLR R5
    FSETCSR R5.B0
    CP $7FC00000 R0.H0
    CP $3F800000 R1.H0
    FCMP R0.H0 R1.H0
    JP qnan_ok
    JMP fail
qnan_ok:
    FGETCSR R5.B0
    AND $10 R5.B0
    CMP $00 R5.B0
    JNZ fail

    ; signaling NaN operand -> unordered (JP) AND FFLAGS.NV set
    CLR R5
    FSETCSR R5.B0
    CP $7F800001 R0.H0
    CP $3F800000 R1.H0
    FCMP R0.H0 R1.H0
    JP snan_ok
    JMP fail
snan_ok:
    FGETCSR R5.B0
    AND $10 R5.B0
    CMP $10 R5.B0
    JNZ fail

    ; ================= divide-by-zero flag (DZ) =================
    CLR R5
    FSETCSR R5.B0
    CP $3F800000 R0.H0
    CLR R1
    FDIV R1.H0 R0.H0
    CMP $7F800000 R0.H0
    JNZ fail
    FGETCSR R5.B0
    AND $08 R5.B0
    CMP $08 R5.B0
    JNZ fail

    ; ================= rounding modes (1.0 / 3.0) =================
    ; RNE (default 0): nearest = 0x3EAAAAAB
    CLR R5
    FSETCSR R5.B0
    CP $3F800000 R0.H0
    CP $40400000 R1.H0
    FDIV R1.H0 R0.H0
    CMP $3EAAAAAB R0.H0
    JNZ fail

    ; RTZ (FRM=1 -> FCSR byte 0x20): toward zero = 0x3EAAAAAA
    CP $20 R5.B0
    FSETCSR R5.B0
    CP $3F800000 R0.H0
    CP $40400000 R1.H0
    FDIV R1.H0 R0.H0
    CMP $3EAAAAAA R0.H0
    JNZ fail

    ; ================= RMM tie (double -> float narrowing) =================
    ; 1 + 2^-24 is the exact midpoint between 1.0 (0x3F800000, even) and the next
    ; float. RNE ties-to-even -> 1.0 ; RMM ties-away -> 0x3F800001.
    CP $80 R5.B0
    FSETCSR R5.B0
    CP $3FF0000010000000 R0.W0
    FCVTFF R0.W0 R1.H0
    CMP $3F800001 R1.H0
    JNZ fail
    CLR R5
    FSETCSR R5.B0
    CP $3FF0000010000000 R0.W0
    FCVTFF R0.W0 R1.H0
    CMP $3F800000 R1.H0
    JNZ fail

    ; ================= subnormals (no flush-to-zero) =================
    ; smallest subnormal + itself = 2 * 2^-149, still subnormal, exact
    CLR R5
    FSETCSR R5.B0
    CP $00000001 R0.H0
    CP $00000001 R1.H0
    FADD R0.H0 R1.H0
    CMP $00000002 R1.H0
    JNZ fail

    ; ================= conversions =================
    ; FCVTFS: 3.0f -> signed int 3
    CP $40400000 R0.H0
    FCVTFS R0.H0 R1.B0
    CMP $03 R1.B0
    JNZ fail
    ; FCVTSF: signed int 3 -> 3.0f
    CP $03 R0.B0
    FCVTSF R0.B0 R1.H0
    CMP $40400000 R1.H0
    JNZ fail
    ; FCVTFF widen: 1.5f -> 1.5d
    CP $3FC00000 R0.H0
    FCVTFF R0.H0 R1.W0
    CMP $3FF8000000000000 R1.W0
    JNZ fail

    ; ---- all checks passed ----
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1.H0
    CP $09 R2
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1.H0
    CP $09 R2
    SYS $01
    HALT

; **********************************************************************************
pass_string:
    STRING "fp: PASS\n\0"

fail_string:
    STRING "fp: FAIL\n\0"
