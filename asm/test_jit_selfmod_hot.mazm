; **********************************************************************************
; Hot self-modifying-code fixture (maize-330, JIT J1; extends asm/test_selfmod.mazm).
;
; The original selfmod fixture executes its target only twice, below any plausible
; JIT hotness threshold, so it never exercises a compiled block. This variant drives
; the target HOT (100 calls), patches its immediate byte through the guest-store
; seam, then drives it hot again and requires the patched behavior. The 4 KiB pad
; below places the target on its own page, so the store invalidates ONLY that page:
; the hot caller blocks on page 0 survive with live chained edges into the dropped
; block, exercising the chain-unlink contract (docs/design/jit.md 3.2a) end to end.
; Interpreted runs pass identically; the fixture asserts architecture, not tiers.
; **********************************************************************************

$0000`0000:
    CLR R6                     ; sum of first 100 calls (expect 100)
    CLR R7                     ; sum of second 100 calls (expect 200)
    CPZ $64 R8                 ; loop count 100
loop1:
    CALL getval
    ADD RV R6
    DEC R8
    JNZ loop1

    ; patch getval's immediate byte from $01 to $02 (guest-store seam)
    CP patchme R2.H0
    ADD $03 R2                 ; +3 = the immediate byte within CP $imm8 RV
    CP $02 R1
    ST R1.B0 @R2

    CPZ $64 R8
loop2:
    CALL getval
    ADD RV R7
    DEC R8
    JNZ loop2

    CPZ $64 R3                 ; 100
    CMP R3 R6
    JNZ fail
    CPZ $C8 R3                 ; 200
    CMP R3 R7
    JNZ fail

    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1.H0
    CP $12 R2                  ; 18 bytes
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1.H0
    CP $12 R2                  ; 18 bytes
    SYS $01
    HALT

pass_string:
    STRING "selfmod hot: PASS\n"
fail_string:
    STRING "selfmod hot: FAIL\n"

; ---- 4 KiB of never-executed padding: pushes getval onto its own 4 KiB page ----
pad:
    STRING ""
    STRING ""
    STRING ""
    STRING ""
    STRING ""
    STRING ""
    STRING ""
    STRING ""

getval:
patchme:
    CP $01 RV                  ; the $01 immediate byte (patchme+3) gets patched to $02
    RET
