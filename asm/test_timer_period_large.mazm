; **********************************************************************************
; Cadence regression for card maize-357 (O(1) armed-timer accounting). period = 1
; (asm/test_timer_period1.mazm) only ever exercises a single-tick crossing, so it
; never touches the bulk path where a JIT block retires n > 1 instructions and the
; countdown must be subtracted across several block boundaries before it crosses zero.
;
; This fixture programs a periodic timer with a period ($07D0 = 2000 ticks) far larger
; than the 512-instruction JIT block cap (docs/design/jit.md 3.3), so under the JIT the
; counter is driven down by the bulk subtract (advance_active_timer(t, n)) across ~125
; block boundaries per period, crossing zero exactly once, then re-arming. The main loop
; is a fat straight-line body (one INC plus a NOP sled, so each JIT block retires many
; instructions) around a backward JMP, which keeps n well above 1 at every boundary.
;
; The handler measures cadence directly. R7 counts main-loop iterations; on each IRQ the
; handler takes delta = R7 - previous-snapshot and asserts it lands in [$20, $400]. A
; correct bulk subtract fires every ~125 iterations (period / body-length), comfortably
; inside the band. A regression that subtracted 1 per block instead of n would fire only
; once every ~2000 iterations, blowing past the high bound; a regression that never
; crossed would time out. On the Nth serviced tick (N = 4) the handler prints PASS and
; halts from within the handler, exactly as test_timer_period1 does.
;
; Because the printed line is a bare "timerpL: PASS\n" with no cadence numbers in it, the
; interpreter, JIT bare, and JIT paged runs all emit byte-identical stdout even though the
; block-boundary coarsening shifts the exact delivery instruction between modes; the
; run-ctest.sh wiring compares interpreter vs. --jit stdout byte-for-byte on top of the
; marker check.
;
; Provisional timer pinout (maize-21): period $40, control $41, status/ack $42, IRQ
; vector 32; vector table base $1000, so entry[32] is at $1100.
; **********************************************************************************

$0000`0000:
    ; ---- install the timer handler at entry[32] ($1100) ----
    CLR R0
    CP timer_handler R0.H0
    CLR R1
    CP $1100 R1
    ST R0 @R1

    ; ---- zero the cadence bookkeeping registers ----
    CLR R7               ; iteration counter (main loop increments once per body)
    CLR R8               ; previous-IRQ snapshot of R7
    CLR R9               ; serviced-tick counter

    ; ---- program the timer: period = 2000 ticks, mode = periodic + enable ----
    CLR R0
    CP $07D0 R0           ; 2000-tick reload, a full-word write to the period port
    OUT R0 $40            ; period register
    CP $03 R0.B0          ; bit0 = enable, bit1 = periodic
    OUT R0.B0 $41         ; control register

    SETINT                ; unmask interrupts

loop:
    INC R7               ; ++iteration
    NOP                   ; NOP sled: fatten the block so each JIT boundary retires n >> 1
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    NOP
    JMP loop              ; the handler drives progress and termination

; **********************************************************************************
; Timer interrupt handler. On each IRQ: delta = R7 - R8, snapshot R8 = R7, ++R9.
; Assert delta is in [$20, $400] (correct cadence is ~125). On the Nth (N = 4) serviced
; tick print PASS and halt; otherwise acknowledge (re-arming the periodic timer) and IRET.
timer_handler:
    ADD $10 SP            ; discard aux + cause (2 words); SP now at the saved RF

    CP R7 R6            ; R6 = current iteration count
    SUB R8 R6           ; R6 = R7 - R8 = iterations since the previous IRQ
    CP R7 R8            ; snapshot previous = current
    INC R9               ; ++serviced ticks

    CMP $20 R6           ; delta below the low band bound?
    JB fail               ; yes -> cadence too fast / no crossing accounting: FAIL
    CMP $0400 R6         ; delta above the high band bound?
    JA fail               ; yes -> bulk subtract not applying n per block: FAIL

    CMP $04 R9           ; reached N = 4 serviced ticks?
    JGE finish

    CLR R6
    OUT R6.B0 $42        ; ack: write 0 to the status register (clears pending, re-arms)
    IRET                  ; pop RF (re-enables interrupts), pop PC (resume the loop)

finish:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1.H0
    CP $0E R2             ; 14 bytes
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1.H0
    CP $0E R2             ; 14 bytes
    SYS $01
    HALT

; **********************************************************************************
pass_string:
    STRING "timerpL: PASS\n\0"

fail_string:
    STRING "timerpL: FAIL\n\0"
