; card maize-115 review follow-forward (blocker 1 of 2): the map to array conversion for
; subreg_size_map / subreg_offset_map / subreg_index_map / subreg_mask_map dropped
; std::unordered_map::operator[]'s default-insert-on-miss guarantee. opflag_subreg is a
; 4-bit field (0x0F), so a decoded-but-undefined subreg encoding of 15 is reachable on the
; VM hot path even though no assembler mnemonic can produce it. This fixture hand-encodes a
; raw LD @imm Rx instruction ($C1, ld_immAddr_reg) with an out-of-range destination subreg
; (byte2 = $0F: register R0, subreg field $0F) via DATA, the same raw-byte technique
; test_mzdis_reserved.mazm uses for reserved opcodes, to reach the previously out-of-bounds
; array read. Before the fix this was an OOB read on subreg_size_map[15] and
; subreg_offset_map[15]/subreg_mask_map[15]; after the fix each returns its
; value-initialized default (0), degrading the load to a zero-width, zero-mask no-op.
; Reaching PASS with R0 provably unmodified proves the read stayed in-bounds and produced
; the exact old default-miss behavior, under the linux-asan-ubsan sanitizer preset.
;
; subreg_index_map's own [15] slot has no live call site that indexes it with a variable
; subreg (only the fixed-width instruction-fetch path uses that memory_module::read
; overload, always with subreg_enum::w0), so it cannot be exercised by a running program;
; it is fixed identically to the other three tables and verified by code inspection instead.

$0000`0000:
    CP $01 R0.B0             ; stage a known value in R0.B0

    DATA $C1                 ; LD @imm Rx (ld_immAddr_reg), raw-encoded
    DATA $00                 ; byte1: imm-size flag 0 (1-byte address literal follows)
    DATA $0F                 ; byte2: dest reg R0 (top nibble $0), dest subreg $0F (INVALID: only $00-$0E defined)
    DATA $00                 ; 1-byte address literal; value is irrelevant (see header comment)

    CP $01 R1.B0              ; R1.B0 = 1 (same value R0.B0 should still hold)
    CMP R1.B0 R0.B0           ; equal -> Z set iff R0.B0 is still 1 (untouched by the OOB-guarded load)
    JZ ok
    JMP fail

ok:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1
    CP $11 R2                ; 17 bytes
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1
    CP $11 R2                ; 17 bytes
    SYS $01
    HALT

pass_string:
    STRING "oob subreg: PASS\n\0"

fail_string:
    STRING "oob subreg: FAIL\n\0"
