; **********************************************************************************
; Negative test for card maize-29: LDZ was removed as redundant. With LD reading exactly
; the destination width, a load never narrows and has nothing to zero-extend, so the
; zero-extending load collapsed onto LD. CPZ remains as the zero-extending copy. The
; assembler must no longer recognize LDZ as an opcode.
; The test harness treats this file as ExpectAsmError: it passes when assembly fails.
; **********************************************************************************

$0000`0000:
    LDZ @$1234 R0.B0        ; error: unknown keyword or opcode 'LDZ' (removed, use LD)
    HALT
