; **********************************************************************************
; SAR (arithmetic / sign-preserving right shift) regression test for card maize-54
; (byte width).
;
; SAR fills vacated high bits with the operand's sign bit (unlike SHR, which
; zero-fills). This test exercises the counts the spec pins down: n=0, n=1,
; n=bits-1 (7), n=bits (8), n=bits+1 (9), on a negative operand ($81), plus a
; non-negative operand ($41) at n>=width to prove the positive path stays 0.
;
; Flags are read from RF.B0 (C=$01, N=$02, V=$04, Z=$10) and isolated with AND.
; Result values are checked by XOR-ing against the expectation (Z set iff equal).
; Any mismatch jumps to fail.
;
; Value under test is $81 (1000_0001, s_byte -127). Expected (SAR $81):
;   n=0  flags unaffected
;   n=1  result $C0  : C set (bit0 out), V clear (SAR never overflows), N set
;   n=7  result $FF  : C clear (bit6 out = 0), V clear, N set, Z clear
;   n=8  result $FF  : saturates to -1, C set (sign bit), N set, Z clear, V clear
;   n=9  result $FF  : saturates to -1 (NOT 0), C set (sign bit), N set, Z clear
;   $41 n=8 result $00 : Z set, N clear, C clear (sign 0), V clear
;
; V is always 0 for SAR (an arithmetic shift replicates the sign bit and can
; never flip it), diverging from SHR which reports the prior sign bit in V at n=1.
;
; Kept single-width (byte) to sidestep the layout-sensitive mazm back-patch defect
; the SHR test notes (unrelated to this card; mazm is out of scope).
; **********************************************************************************

$0000`0000:
    ; ---- SAR n=0 : flags unaffected (C preserved set) ----
    CP $81 R0.B0
    SETCRY
    SAR $00 R0.B0
    JB sar0a_ok
    JMP fail
sar0a_ok:
    ; ---- SAR n=0 : C preserved clear ----
    CP $81 R0.B0
    CLRCRY
    SAR $00 R0.B0
    JB fail

    ; ---- SAR n=0 : Z preserved SET (nonzero operand) ----
    CLR R8
    AND $00 R8.B0           ; result 0 -> Z set
    CP $81 R0.B0            ; nonzero operand (CP is flag-neutral)
    SAR $00 R0.B0           ; count 0: Z must stay set
    CP RF.B0 R9.B0          ; snapshot flags (CP is flag-neutral)
    AND $10 R9.B0           ; isolate Z
    JZ fail                 ; Z cleared -> regression

    ; ---- SAR n=0 : Z preserved CLEAR (zero operand) ----
    CP $01 R8.B0
    AND $01 R8.B0           ; result 1 -> Z clear
    CLR R0                  ; zero operand (CLR is flag-neutral)
    SAR $00 R0.B0           ; count 0: Z must stay clear
    CP RF.B0 R9.B0
    AND $10 R9.B0           ; isolate Z
    JNZ fail                ; Z set -> regression

    ; ---- SAR n=0 : N preserved SET (operand high bit clear) ----
    CP $80 R8.B0
    AND $80 R8.B0           ; result $80 -> N set
    CP $01 R0.B0            ; operand high bit clear
    SAR $00 R0.B0           ; count 0: N must stay set
    CP RF.B0 R9.B0
    AND $02 R9.B0           ; isolate N
    JZ fail                 ; N cleared -> regression

    ; ---- SAR n=0 : N preserved CLEAR (operand high bit set) ----
    CP $01 R8.B0
    AND $01 R8.B0           ; result 1 -> N clear
    CP $81 R0.B0            ; operand high bit set
    SAR $00 R0.B0           ; count 0: N must stay clear
    CP RF.B0 R9.B0
    AND $02 R9.B0           ; isolate N
    JNZ fail                ; N set -> regression

    ; ---- SAR n=1 on $81 : result $C0, C set, V clear, N set ----
    CP $81 R0.B0
    SAR $01 R0.B0
    CP RF.B0 R9.B0          ; snapshot flags first
    CP R0.B0 R8.B0          ; result value
    XOR $C0 R8.B0           ; 0 iff result == $C0
    JNZ fail
    CP R9.B0 R8.B0
    AND $01 R8.B0           ; C set
    JZ fail
    CP R9.B0 R8.B0
    AND $04 R8.B0           ; V clear
    JNZ fail
    CP R9.B0 R8.B0
    AND $02 R8.B0           ; N set
    JZ fail

    ; ---- SAR n=7 on $81 : result $FF, C clear (bit6=0), V clear, N set, Z clear ----
    CP $81 R0.B0
    SAR $07 R0.B0
    CP RF.B0 R9.B0
    CP R0.B0 R8.B0
    XOR $FF R8.B0           ; 0 iff result == $FF
    JNZ fail
    CP R9.B0 R8.B0
    AND $01 R8.B0           ; C clear
    JNZ fail
    CP R9.B0 R8.B0
    AND $04 R8.B0           ; V clear
    JNZ fail
    CP R9.B0 R8.B0
    AND $02 R8.B0           ; N set
    JZ fail
    CP R9.B0 R8.B0
    AND $10 R8.B0           ; Z clear
    JNZ fail

    ; ---- SAR n=8 on $81 : saturates to $FF, C set (sign), N set, Z clear, V clear ----
    CP $81 R0.B0
    SAR $08 R0.B0
    CP RF.B0 R9.B0
    CP R0.B0 R8.B0
    XOR $FF R8.B0           ; 0 iff result == $FF
    JNZ fail
    CP R9.B0 R8.B0
    AND $01 R8.B0           ; C set (sign bit)
    JZ fail
    CP R9.B0 R8.B0
    AND $02 R8.B0           ; N set
    JZ fail
    CP R9.B0 R8.B0
    AND $10 R8.B0           ; Z clear
    JNZ fail
    CP R9.B0 R8.B0
    AND $04 R8.B0           ; V clear
    JNZ fail

    ; ---- SAR n=9 on $81 : over-width saturates to $FF (NOT 0), C set (sign), N set, Z clear ----
    CP $81 R0.B0
    SAR $09 R0.B0
    CP RF.B0 R9.B0
    CP R0.B0 R8.B0
    XOR $FF R8.B0           ; 0 iff result == $FF -> proves saturation to -1, not 0
    JNZ fail
    CP R9.B0 R8.B0
    AND $01 R8.B0           ; C set (sign bit)
    JZ fail
    CP R9.B0 R8.B0
    AND $02 R8.B0           ; N set
    JZ fail
    CP R9.B0 R8.B0
    AND $10 R8.B0           ; Z clear
    JNZ fail

    ; ---- SAR $41 n=8 : non-negative operand saturates to $00, Z set, N clear, C clear, V clear ----
    CP $41 R0.B0
    SAR $08 R0.B0
    CP RF.B0 R9.B0
    CP R0.B0 R8.B0
    XOR $00 R8.B0           ; leaves R8; Z set iff result == 0
    JNZ fail
    CP R9.B0 R8.B0
    AND $10 R8.B0           ; Z set
    JZ fail
    CP R9.B0 R8.B0
    AND $02 R8.B0           ; N clear
    JNZ fail
    CP R9.B0 R8.B0
    AND $01 R8.B0           ; C clear (sign 0)
    JNZ fail
    CP R9.B0 R8.B0
    AND $04 R8.B0           ; V clear
    JNZ fail

    ; ---- all checks passed ----
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP pass_string R1
    CP $10 R2               ; 16 bytes
    SYS $01
    HALT

fail:
    CLR R0
    CLR R1
    CLR R2
    CP $01 R0
    CP fail_string R1
    CP $10 R2               ; 16 bytes
    SYS $01
    HALT

; **********************************************************************************
pass_string:
    STRING "flags sar: PASS\n\0"

fail_string:
    STRING "flags sar: FAIL\n\0"
