{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-llvm-mingw-debug",
      "displayName": "Windows (llvm-mingw, Debug)",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "${sourceDir}/.toolchains/llvm-mingw/bin/x86_64-w64-mingw32-clang.exe",
        "CMAKE_CXX_COMPILER": "${sourceDir}/.toolchains/llvm-mingw/bin/x86_64-w64-mingw32-clang++.exe",
        "CMAKE_EXE_LINKER_FLAGS": "-static"
      }
    },
    {
      "name": "windows-msys2-debug",
      "displayName": "Windows (MSYS2 UCRT64 GCC, Debug, fallback)",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "C:/msys64/ucrt64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/msys64/ucrt64/bin/g++.exe",
        "CMAKE_EXE_LINKER_FLAGS": "-static"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux (Debug)",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS (Debug)",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    }
  ],
  "buildPresets": [
    { "name": "windows-llvm-mingw-debug", "configurePreset": "windows-llvm-mingw-debug" },
    { "name": "windows-msys2-debug", "configurePreset": "windows-msys2-debug" },
    { "name": "linux-debug", "configurePreset": "linux-debug" },
    { "name": "macos-debug", "configurePreset": "macos-debug" }
  ],
  "testPresets": [
    { "name": "windows-llvm-mingw-debug", "configurePreset": "windows-llvm-mingw-debug" },
    { "name": "windows-msys2-debug", "configurePreset": "windows-msys2-debug" },
    { "name": "linux-debug", "configurePreset": "linux-debug" },
    { "name": "macos-debug", "configurePreset": "macos-debug" }
  ]
}
