maize-94: mv is rename-only (cross-device cp+rm fallback deferred).

Upstream file/function: mv.c, mv().
Why: the EXDEV fallback pulls in cp() plus the recursive-rm engine (recurse.c /
unlinkat / fdopendir), whose metadata and directory-recursion surface is deferred
to maize-245. On a single hostfs mount rename never returns EXDEV, so wave-1 mv is
rename-only and reports any other failure rather than faking the copy path.
diff --git a/mv.c b/mv.c
index 8441f9c..e065ff5 100644
--- a/mv.c
+++ b/mv.c
@@ -13,25 +13,16 @@ static int mv_status = 0;
 static int
 mv(const char *s1, const char *s2, int depth)
 {
-	struct recursor r = { .fn = rm, .follow = 'P' };
+	(void)depth;
 
 	if (!rename(s1, s2))
 		return 0;
-	if (errno == EXDEV) {
-		cp_aflag = cp_rflag = cp_pflag = 1;
-		cp_follow = 'P';
-		cp_status = 0;
-		rm_status = 0;
-		cp(s1, s2, depth);
-		if (cp_status == 0)
-			recurse(AT_FDCWD, s1, NULL, &r);
-		if (cp_status || rm_status)
-			mv_status = 1;
-	} else {
-		weprintf("%s -> %s:", s1, s2);
-		mv_status = 1;
-	}
-
+	/* maize-94: a cross-device move (rename -> EXDEV) needs the cp + recursive-rm
+	 * fallback, whose file-metadata and directory-recursion surface is deferred to
+	 * maize-245; on a single hostfs mount rename never returns EXDEV, so wave-1 mv
+	 * is rename-only and reports any other failure rather than faking the copy. */
+	weprintf("%s -> %s:", s1, s2);
+	mv_status = 1;
 	return 0;
 }
 
