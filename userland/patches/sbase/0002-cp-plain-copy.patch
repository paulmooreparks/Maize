-			}
-		} else {
-			if (lchown(s2, st.st_uid, st.st_gid) < 0) {
-				weprintf("lchown %s:", s2);
-				cp_status = 1;
-				return 0;
-			}
-		}
-	}
-
 	return 0;
 }
