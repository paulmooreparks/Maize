maize-94: cp() is a plain content copy (no metadata / symlink / device surface).

Upstream file/function: libutil/cp.c, cp().
Why: hostfs has no path-relative *at, no symlinks, and no file-metadata syscalls
(owner/mode/times/device nodes), so the upstream symlink, device-node, and -p/-a
preserve branches cannot link (readlink/symlink/mknod/utimensat/chown/chmod/lchown,
struct stat st_atim/st_mtim/st_rdev). Wave-1 cp is a plain content copy of regular
files plus directory recursion (stat composite + concat), preserving no metadata.
fstatat is replaced by the stat() composite. The deferred metadata surface is
maize-245; drop the branches rather than fake them (maize-90 rule).
diff --git a/libutil/cp.c b/libutil/cp.c
index 23275ac..92764c4 100644
--- a/libutil/cp.c
+++ b/libutil/cp.c
@@ -9,7 +9,6 @@
 #include <sys/stat.h>
 #include <sys/types.h>
 #include <unistd.h>
-#include <utime.h>
 
 #include "../fs.h"
 #include "../util.h"
@@ -26,17 +25,19 @@ int
 cp(const char *s1, const char *s2, int depth)
 {
 	DIR *dp;
-	int f1, f2, flags = 0;
+	int f1, f2;
 	struct dirent *d;
 	struct stat st;
-	struct timespec times[2];
-	ssize_t r;
-	char target[PATH_MAX], ns1[PATH_MAX], ns2[PATH_MAX];
-
-	if (cp_follow == 'P' || (cp_follow == 'H' && depth))
-		flags |= AT_SYMLINK_NOFOLLOW;
-
-	if (fstatat(AT_FDCWD, s1, &st, flags) < 0) {
+	char ns1[PATH_MAX], ns2[PATH_MAX];
+
+	/* maize-94: hostfs has no path-relative *at, no symlinks, and no file-metadata
+	 * surface (owner / mode / times / device nodes) yet; that whole surface is
+	 * deferred to maize-245. Wave-1 cp is a plain content copy (regular files plus
+	 * directory recursion): stat via the libc composite stat(), copy bytes with
+	 * concat(), preserve no metadata. The upstream symlink, device-node, and -p/-a
+	 * preserve branches are dropped here rather than faked, so this overlay never
+	 * calls fstatat / readlink / symlink / mknod / utimensat / chown / chmod. */
+	if (stat(s1, &st) < 0) {
 		weprintf("stat %s:", s1);
 		cp_status = 1;
 		return 0;
@@ -45,20 +46,7 @@ cp(const char *s1, const char *s2, int depth)
 	if (cp_vflag)
 		printf("%s -> %s\n", s1, s2);
 
-	if (S_ISLNK(st.st_mode)) {
-		if ((r = readlink(s1, target, sizeof(target) - 1)) >= 0) {
-			target[r] = '\0';
-			if (cp_fflag && unlink(s2) < 0 && errno != ENOENT) {
