-			weprintf("mknod %s:", s2);
-			cp_status = 1;
-			return 0;
-		}
 	} else {
 		if ((f1 = open(s1, O_RDONLY)) < 0) {
 			weprintf("open %s:", s1);
@@ -137,34 +114,5 @@ cp(const char *s1, const char *s2, int depth)
 		close(f2);
 	}
 
-	if (cp_aflag || cp_pflag) {
-		/* atime and mtime */
-		times[0] = st.st_atim;
-		times[1] = st.st_mtim;
-		if (utimensat(AT_FDCWD, s2, times, AT_SYMLINK_NOFOLLOW) < 0) {
-			weprintf("utimensat %s:", s2);
-			cp_status = 1;
-		}
-
-		/* owner and mode */
-		if (!S_ISLNK(st.st_mode)) {
-			if (chown(s2, st.st_uid, st.st_gid) < 0) {
-				weprintf("chown %s:", s2);
-				cp_status = 1;
-				st.st_mode &= ~(S_ISUID | S_ISGID);
-			}
-			if (chmod(s2, st.st_mode) < 0) {
