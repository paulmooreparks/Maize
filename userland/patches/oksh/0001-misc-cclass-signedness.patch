@@ -721,7 +721,7 @@ posix_cclass(const unsigned char *pattern, int test, const unsigned char **ep)
 	size_t len;
 	int rval = 0;
 
-	if ((colon = strchr(pattern, ':')) == NULL || colon[1] != MAGIC) {
+	if ((colon = (const unsigned char *)strchr((const char *)pattern, ':')) == NULL || colon[1] != MAGIC) {
 		*ep = pattern - 2;
 		return -1;
 	}
@@ -729,7 +729,7 @@ posix_cclass(const unsigned char *pattern, int test, const unsigned char **ep)
